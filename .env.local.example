# Supabase プロジェクトの Settings > API から取得してください
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# anon / public key。ブラウザに公開される前提のキーです（RLSで保護されます）。
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# service role key。絶対にブラウザへ公開しないでください（サーバー側のみで使用）。
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ユーザー招待を許可するメールドメイン（カンマ区切り、@より後ろの部分のみ）。
# 未設定の場合は誰も招待できません（fail-closed）。
# 例: ALLOWED_EMAIL_DOMAINS=example.co.jp,group-example.co.jp
ALLOWED_EMAIL_DOMAINS=

# Vercel Cron から /api/cron/process-notifications を呼び出す際の認証に使う秘密文字列。
# Vercel の Environment Variables に設定すると、Vercel Cron が自動で
# `Authorization: Bearer <値>` ヘッダーを付けて呼び出してくれます。
# 例: openssl rand -hex 32 で生成
CRON_SECRET=

# （任意）Microsoft Teams の Incoming Webhook URL。設定すると通知プロバイダーとして
# 自動的に有効化されます（社内で使用中のサービス）。未設定でもアプリの他の機能には
# 影響しません（開発用のログ出力プロバイダーのみが動作します）。
TEAMS_WEBHOOK_URL=

# （任意）Slack Incoming Webhook のURL。設定すると通知プロバイダーとして自動的に有効化されます。
SLACK_WEBHOOK_URL=

# ------------------------------------------------------------
# 以下は旧・共有パスワード方式の管理者認証で使っていた変数です。
# Supabase Auth（個人アカウント単位のログイン）への移行に伴い廃止しました。
# 既存の .env.local に残っていても読み込まれません。安全のため削除してください。
# ------------------------------------------------------------
# ADMIN_PASSWORD=change-me
# ADMIN_SESSION_SECRET=change-this-to-a-random-string
